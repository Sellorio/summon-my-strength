@using SummonMyStrength.Api.ChampSelect
@using SummonMyStrength.Maui.Data
@inject IUserSettingsService UserSettingsService
@inject IChampSelectSessionService ChampSelectSessionService
@inject IChampSelectBenchService ChampSelectBenchService
@inject IChampSelectChampionTradeService ChampSelectChampionTradeService

<ComponentSettings SectionName="Champ-Select">
    <AramPreferenceSettings />
</ComponentSettings>

@code {
    private UserSettings _userSettings;
    private List<(long CellId, int ChampionId)> _attemptedTrades;
    private int? _lastChampionId;
    private HashSet<int> _lastBenchChampionIds = [];
    private int? _pendingAutoBenchSwapChampionId;
    private int? _blockedReverseBenchChampionId;
    private int? _blockedReverseWhileChampionId;

    protected override async Task OnInitializedAsync()
    {
        _userSettings = await UserSettingsService.GetSettingsAsync();

        ChampSelectSessionService.ChampSelectSessionCreated += SessionCreatedAsync;
        ChampSelectSessionService.ChampSelectSessionUpdated += SessionChangedAsync;
    }

    private async Task SessionCreatedAsync(ChampSelectSession session)
    {
        _attemptedTrades = [];
        _lastChampionId = null;
        _lastBenchChampionIds = [];
        _pendingAutoBenchSwapChampionId = null;
        _blockedReverseBenchChampionId = null;
        _blockedReverseWhileChampionId = null;
        await SessionChangedAsync(session);
    }

    private async Task SessionChangedAsync(ChampSelectSession session)
    {
        _attemptedTrades ??= [];

        TrackManualBenchSwap(session);

        if (session?.Player == null)
        {
            return;
        }

        if (session.BenchEnabled && _userSettings.AutoTradeForPreferredAramChampions)
        {
            var ongoingTrade = await ChampSelectChampionTradeService.GetOngoingTradeAsync();
            var currentlyTrading = ongoingTrade?.State is ChampSelectTradeState.Sent or ChampSelectTradeState.Received;

            if (currentlyTrading)
            {
                return;
            }

            var trades = session.Trades ?? [];
            var currentRank = GetAramChampionRank(session.Player.ChampionId);
            var availableTradesByCellId = trades
                .Where(x => x.State == ChampSelectTradeState.Available)
                .GroupBy(x => x.CellId)
                .ToDictionary(x => x.Key, x => x.OrderBy(y => y.Id).ToArray());

            var highestRankBenchChamp = (session.BenchChampions ?? [])
                .Select(x => new { Rank = GetAramChampionRank(x.ChampionId), ChampionId = x.ChampionId })
                .Where(x => x.ChampionId != _blockedReverseBenchChampionId || session.Player.ChampionId != _blockedReverseWhileChampionId)
                .OrderBy(x => x.Rank)
                .LastOrDefault();

            var highestRankAllyChamp =
                (session.MyTeam ?? [])
                    .Select(x => new { Rank = GetAramChampionRank(x.ChampionId), CellId = x.CellId, ChampionId = x.ChampionId })
                    .Where(x => x.CellId != session.Player.CellId)                                                             // exclude me
                    .Where(x => !_attemptedTrades.Contains((x.CellId, x.ChampionId)))                                       // only attempt to trade once per ally
                    .Where(x => availableTradesByCellId.ContainsKey(x.CellId))                                               // exclude allies that rejected trade requests
                    .OrderBy(x => x.Rank)
                    .LastOrDefault();

            var highestRankAlly = highestRankAllyChamp?.Rank ?? 0;
            var highestRankBench = highestRankBenchChamp?.Rank ?? 0;

            if (highestRankBenchChamp != null && highestRankBench > highestRankAlly && highestRankBench > currentRank)
            {
                // How are bench cooldowns handled? I don't see data supporting it in the API
                _pendingAutoBenchSwapChampionId = highestRankBenchChamp.ChampionId;
                await ChampSelectBenchService.SwapWithBenchAsync(highestRankBenchChamp.ChampionId);
            }
            else if (highestRankAllyChamp != null && highestRankAlly > currentRank)
            {
                // trade id is generated when loading into champ select and is unique for each Player -> Player combination.
                // all entries in the Trades list are created immediately and states are set to Avaiable.
                var tradeRequested = await TryRequestTradeAsync(availableTradesByCellId[highestRankAllyChamp.CellId]);

                if (tradeRequested)
                {
                    _attemptedTrades.Add((highestRankAllyChamp.CellId, highestRankAllyChamp.ChampionId));
                }
            }
        }
    }

    private async Task<bool> TryRequestTradeAsync(IEnumerable<ChampSelectTradeContract> availableTrades)
    {
        foreach (var trade in availableTrades)
        {
            var requestedTrade = await ChampSelectChampionTradeService.RequestTradeAsync(trade.Id);

            if (requestedTrade != null)
            {
                return true;
            }
        }

        return false;
    }

    private void TrackManualBenchSwap(ChampSelectSession session)
    {
        var currentChampionId = session?.Player?.ChampionId;
        var currentBenchChampionIds = (session?.BenchChampions ?? []).Select(x => x.ChampionId).ToHashSet();

        if (_blockedReverseWhileChampionId.HasValue && currentChampionId != _blockedReverseWhileChampionId)
        {
            _blockedReverseBenchChampionId = null;
            _blockedReverseWhileChampionId = null;
        }

        if (_lastChampionId.HasValue && currentChampionId.HasValue && _lastChampionId != currentChampionId)
        {
            if (_pendingAutoBenchSwapChampionId == currentChampionId)
            {
                _pendingAutoBenchSwapChampionId = null;
            }
            else if (_lastBenchChampionIds.Contains(currentChampionId.Value) && currentBenchChampionIds.Contains(_lastChampionId.Value))
            {
                _pendingAutoBenchSwapChampionId = null;
                _blockedReverseBenchChampionId = _lastChampionId;
                _blockedReverseWhileChampionId = currentChampionId;
            }
        }

        _lastChampionId = currentChampionId;
        _lastBenchChampionIds = currentBenchChampionIds;
    }

    private int GetAramChampionRank(int championId)
    {
        var index = _userSettings.PreferredAramChampionGroups.FindIndex(x => x.ChampionIds.Contains(championId));
        return index == -1 ? 0 : (_userSettings.PreferredAramChampionGroups.Count - index);
    }
}
