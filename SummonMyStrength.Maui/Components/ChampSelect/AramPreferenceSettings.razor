@using SummonMyStrength.Api.Collections.Champions
@using SummonMyStrength.Maui.Components.Collections.Champions
@using SummonMyStrength.Maui.Components.Common.DragDrop
@using SummonMyStrength.Maui.Data
@inject IUserSettingsService UserSettingsService
@inject IDialogService DialogService
@inject IChampionService ChampionService

<MudText Typo="Typo.subtitle1">ARAM Champion Preferences</MudText>

@if (_userSettings != null)
{
    <SettingsCheckbox Label="Auto Trade?" Value="_userSettings.AutoTradeForPreferredAramChampions" ValueChanged="AutoTradeForPreferredAramChampionsChangedAsync" />

    <div class="preferred-aram-groups">
        @for (var index = 0; index < _userSettings.PreferredAramChampionGroups.Count; index++)
        {
            var groupIndex = index;
            var group = _userSettings.PreferredAramChampionGroups[groupIndex];

            <Draggable T="AramChampionPreferenceGroup" GroupKey="@AramPreferenceGroupListKey" Key="@group" OnDragCompleted="() => RemoveGroup(group)" OnInsertDrop="x => InsertGroupAsync(group, x)" DragHandleSelector=".preferred-aram-group-drag-handle">
                <div class="preferred-aram-group">
                    <div class="preferred-aram-group-header">
                        <div class="preferred-aram-group-drag-handle">
                            <MudText Typo="Typo.subtitle2">Priority @(groupIndex + 1)</MudText>
                        </div>

                        <div class="preferred-aram-group-actions">
                            <MudIconButton Icon="@Icons.Material.Outlined.Add" OnClick="() => AddChampionToGroupAsync(groupIndex)" />
                            <MudIconButton Icon="@Icons.Material.Outlined.Delete" OnClick="() => RemoveGroupAsync(groupIndex)" />
                        </div>
                    </div>

                    <div class="preferred-aram-champs">
                        @foreach (var championId in group.ChampionIds)
                        {
                            if (!_championsById.TryGetValue(championId, out var champion))
                            {
                                continue;
                            }

                            var dragItem = new AramPreferenceDragItem(championId, groupIndex);

                            <Draggable T="AramPreferenceDragItem" GroupKey="@AramPreferenceGroupKey" Key="@dragItem" OnDragCompleted="() => RemoveChampionFromGroup(groupIndex, championId)" OnInsertDrop="x => InsertChampionIntoGroupAsync(groupIndex, championId, x)">
                                <div class="preferred-aram-champ">
                                    <div class="champion-icon-wrapper">
                                        <img class="champion-icon" alt="@champion.Name" src="@ChampionService.GetIconUrl(champion)">
                                    </div>
                                    <span class="champion-name">@champion.Name</span>
                                    <MudIconButton Class="remove-button" Icon="@Icons.Material.Outlined.Close" OnClick="() => RemoveChampionFromGroupAsync(groupIndex, championId)" />
                                </div>
                            </Draggable>
                        }

                        <DragDropsite T="AramPreferenceDragItem" GroupKey="@AramPreferenceGroupKey" OnDrop="x => AppendChampionToGroupAsync(groupIndex, x)" />
                    </div>
                </div>
            </Draggable>
        }

        <DragDropsite T="AramChampionPreferenceGroup" GroupKey="@AramPreferenceGroupListKey" OnDrop="AppendGroupAsync">
            <ChildContent Context="dropPreview">
                <div class="preferred-aram-group-list-dropzone">
                    <div class="preferred-aram-drop-hint">Drop here to move a priority group to the end.</div>
                    @dropPreview
                </div>
            </ChildContent>
        </DragDropsite>

        <button class="add-preferred-aram-group" @onclick="AddGroupAsync">
            <MudIcon Icon="@Icons.Material.Outlined.Add" />
        </button>
    </div>
}

@code {
    private UserSettings _userSettings;
    private IReadOnlyDictionary<int, Champion> _championsById = new Dictionary<int, Champion>();
    private const string AramPreferenceGroupKey = "aram-preference";
    private const string AramPreferenceGroupListKey = "aram-preference-group";

    protected override async Task OnInitializedAsync()
    {
        _userSettings = await UserSettingsService.GetSettingsAsync();
        _championsById = (await ChampionService.GetChampionsAsync()).ToDictionary(x => x.Id);
    }

    private async Task AutoTradeForPreferredAramChampionsChangedAsync(bool newValue)
    {
        _userSettings.AutoTradeForPreferredAramChampions = newValue;
        await UserSettingsService.SaveSettingsAsync();
    }

    private async Task AddGroupAsync()
    {
        _userSettings.PreferredAramChampionGroups.Add(new AramChampionPreferenceGroup());
        await UserSettingsService.SaveSettingsAsync();
    }

    private async Task AddChampionToGroupAsync(int groupIndex)
    {
        var existingChampionIds = _userSettings.PreferredAramChampionGroups.SelectMany(x => x.ChampionIds).ToArray();

        var dialogParameters = new DialogParameters<ChampionSelectDialog>();
        dialogParameters.Add(x => x.ExcludedChampionIds, existingChampionIds);
        var dialogReference = await DialogService.ShowAsync<ChampionSelectDialog>(null, dialogParameters);
        var dialogResult = await dialogReference.Result;

        if (dialogResult.Canceled)
        {
            return;
        }

        var newChampionId = (int)dialogResult.Data;

        await AppendChampionToGroupAsync(groupIndex, new AramPreferenceDragItem(newChampionId, groupIndex));
    }

    private async Task AppendChampionToGroupAsync(int groupIndex, AramPreferenceDragItem dragItem)
    {
        if (!TryGetGroup(groupIndex, out var group))
        {
            return;
        }

        RemoveChampionFromAllGroups(dragItem.ChampionId);
        group.ChampionIds.Add(dragItem.ChampionId);
        await UserSettingsService.SaveSettingsAsync();
    }

    private async Task InsertChampionIntoGroupAsync(int groupIndex, int beforeChampionId, AramPreferenceDragItem dragItem)
    {
        if (!TryGetGroup(groupIndex, out var group))
        {
            return;
        }

        RemoveChampionFromAllGroups(dragItem.ChampionId);

        var index = group.ChampionIds.IndexOf(beforeChampionId);
        if (index == -1)
        {
            group.ChampionIds.Add(dragItem.ChampionId);
        }
        else
        {
            group.ChampionIds.Insert(index, dragItem.ChampionId);
        }

        await UserSettingsService.SaveSettingsAsync();
    }

    private async Task RemoveChampionFromGroupAsync(int groupIndex, int championId)
    {
        RemoveChampionFromGroup(groupIndex, championId);
        await UserSettingsService.SaveSettingsAsync();
    }

    private async Task RemoveGroupAsync(int groupIndex)
    {
        if (groupIndex < 0 || groupIndex >= _userSettings.PreferredAramChampionGroups.Count)
        {
            return;
        }

        _userSettings.PreferredAramChampionGroups.RemoveAt(groupIndex);
        await UserSettingsService.SaveSettingsAsync();
    }

    private async Task InsertGroupAsync(AramChampionPreferenceGroup beforeGroup, AramChampionPreferenceGroup group)
    {
        RemoveGroup(group);

        var index = _userSettings.PreferredAramChampionGroups.IndexOf(beforeGroup);
        if (index == -1)
        {
            _userSettings.PreferredAramChampionGroups.Add(group);
        }
        else
        {
            _userSettings.PreferredAramChampionGroups.Insert(index, group);
        }

        await UserSettingsService.SaveSettingsAsync();
    }

    private async Task AppendGroupAsync(AramChampionPreferenceGroup group)
    {
        RemoveGroup(group);
        _userSettings.PreferredAramChampionGroups.Add(group);
        await UserSettingsService.SaveSettingsAsync();
    }

    private void RemoveGroup(AramChampionPreferenceGroup group)
    {
        _userSettings.PreferredAramChampionGroups.Remove(group);
    }

    private void RemoveChampionFromGroup(int groupIndex, int championId)
    {
        if (TryGetGroup(groupIndex, out var group))
        {
            group.ChampionIds.Remove(championId);
        }
    }

    private void RemoveChampionFromAllGroups(int championId)
    {
        foreach (var group in _userSettings.PreferredAramChampionGroups)
        {
            group.ChampionIds.Remove(championId);
        }
    }

    private bool TryGetGroup(int groupIndex, out AramChampionPreferenceGroup group)
    {
        if (groupIndex >= 0 && groupIndex < _userSettings.PreferredAramChampionGroups.Count)
        {
            group = _userSettings.PreferredAramChampionGroups[groupIndex];
            return true;
        }

        group = default!;
        return false;
    }

    private sealed record AramPreferenceDragItem(int ChampionId, int GroupIndex);
}
